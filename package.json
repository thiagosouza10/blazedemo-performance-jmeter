  "main": "index.js",
  "scripts": {
    "test": "apache-jmeter-5.6.3\\bin\\jmeter.bat -n -t blazedemo.jmx -l result.jtl -e -o logs",
    "clean:report": "rm -rf logs result.jtl jmeter.log",
    "load:test": "apache-jmeter-5.6.3\\bin\\jmeter.bat -n -t blazedemo.jmx -Jthreads_carga=250 -l result.jtl -e -o logs",
    "spike:test": "apache-jmeter-5.6.3\\bin\\jmeter.bat -n -t blazedemo.jmx -Jthreads_pico=250 -l result.jtl -e -o logs"
  }
